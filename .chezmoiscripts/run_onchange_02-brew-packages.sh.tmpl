{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# run_onchange_02-brew-packages.sh.tmpl
#
# chezmoi re-runs this script whenever its rendered content changes —
# i.e. whenever you edit the package lists below. It is safe to run
# multiple times; brew bundle is idempotent.
#
# Machine: {{ .machine }}
set -euo pipefail

ARCH=$(uname -m)
if [[ "$ARCH" == "arm64" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
else
  eval "$(/usr/local/bin/brew shellenv)"
fi

echo "▶ Running brew bundle (machine: {{ .machine }})..."
brew bundle --file=/dev/stdin <<'BREWFILE'

# ── taps ──────────────────────────────────────────────────────────────────────
tap "codecrafters-io/tap"
tap "dart-lang/dart"
tap "domt4/autoupdate"
tap "hashicorp/tap"
tap "homebrew/bundle"

# ── core CLI utilities ────────────────────────────────────────────────────────
brew "coreutils"          # GNU core utils (gls, gdate, etc.)
brew "moreutils"          # sponge, ts, vidir, etc.
brew "gnu-sed"            # gsed
brew "openssl@3"
brew "git"
brew "wget"
brew "curl"

# ── shell & terminal ──────────────────────────────────────────────────────────
brew "antigen"                       # zsh plugin manager
brew "bash-completion"
brew "zsh-history-substring-search"
brew "hstr"                          # shell history browser
brew "peco"                          # interactive filter
brew "z"                             # jump to frecent dirs
brew "tmux"
brew "htop"

# ── search & file tools ───────────────────────────────────────────────────────
brew "bat"                           # cat with syntax highlighting
brew "ripgrep"                       # fast grep
brew "tree"
brew "jq"
brew "lynx"

# ── documentation ─────────────────────────────────────────────────────────────
brew "tldr"
brew "cheat"
brew "pandoc"

# ── mac app store cli ─────────────────────────────────────────────────────────
brew "mas"

# ── devops / infra ────────────────────────────────────────────────────────────
brew "ansible"
brew "awscli"
brew "hashicorp/tap/terraform"

# ── languages: python ─────────────────────────────────────────────────────────
brew "pyenv"
brew "python@3.12"
brew "pipx"

# ── languages: node ───────────────────────────────────────────────────────────
brew "node"
brew "nvm"
brew "yarn"
brew "yarn-completion"

# ── languages: go ─────────────────────────────────────────────────────────────
brew "go"

# ── languages: java ───────────────────────────────────────────────────────────
brew "openjdk"
brew "gradle"
brew "maven"

# ── databases ─────────────────────────────────────────────────────────────────
brew "postgresql@15"

# ── editors ───────────────────────────────────────────────────────────────────
brew "emacs"

# ── security ──────────────────────────────────────────────────────────────────
brew "gnupg"

# ── misc dev ──────────────────────────────────────────────────────────────────
brew "graphviz"
brew "autoconf"
brew "icu4c@76"
brew "chezmoi"
brew "exercism"
brew "codecrafters-io/tap/codecrafters"

# ── casks: productivity & communication (all machines) ───────────────────────
cask "1password"
cask "alfred"
cask "arc"
cask "bear"
cask "caffeine"
cask "discord"
cask "dozer"
cask "dropbox"
cask "firefox"
cask "ghostty"
cask "google-chrome"
cask "google-drive"
cask "keepassxc"
cask "mattermost"
cask "moom"
cask "netnewswire"
cask "nightfall"
cask "onyx"
cask "slack"
cask "whatsapp"

# ── casks: creativity & media ─────────────────────────────────────────────────
cask "calibre"
cask "drawio"
cask "gimp"
cask "grandperspective"
cask "guitar-pro"
cask "imageoptim"
cask "musescore"
cask "tidal"
cask "vlc"
cask "vox"

# ── casks: dev tools (all machines) ──────────────────────────────────────────
cask "cakebrew"
cask "claude-code"
cask "devtoys"
cask "iterm2"
cask "jetbrains-toolbox"
cask "miro"
cask "postman"
cask "rapidapi"

# ── casks: system utilities ───────────────────────────────────────────────────
cask "coconutbattery"
cask "iglance"
cask "karabiner-elements"
cask "topnotch"

BREWFILE

# ── work-only packages ────────────────────────────────────────────────────────
{{ if eq .machine "work" -}}
echo "▶ Installing work-only packages..."
brew bundle --file=/dev/stdin <<'WORK_BREWFILE'


# Work CLI tools
brew "ssh-copy-id"
brew "sshuttle"
brew "wrk"
brew "minio"
brew "postgresql@14"
brew "python@3.10"

# Work languages / frameworks
brew "cocoapods"
brew "dart-lang/dart/dart"

# Work casks
cask "android-studio"
cask "apache-directory-studio"
cask "citrix-workspace"
cask "favro"
cask "flutter"
cask "insomnia"
cask "intellij-idea"
cask "jetbrains-toolbox"
cask "oracle-jdk"
cask "temurin"
cask "vagrant"

WORK_BREWFILE
{{ end -}}

# ── personal-only packages ────────────────────────────────────────────────────
{{ if eq .machine "personal" -}}
echo "▶ Installing personal-only packages..."
brew bundle --file=/dev/stdin <<'PERSONAL_BREWFILE'

cask "anaconda"
cask "app-fair"

PERSONAL_BREWFILE
{{ end -}}

# ── mac app store apps ────────────────────────────────────────────────────────
# NOTE: You must be signed into the Mac App Store before this section runs.
# If mas fails, sign in manually and re-run: chezmoi apply
echo "▶ Installing Mac App Store apps (requires App Store sign-in)..."
brew bundle --file=/dev/stdin <<'MAS_BREWFILE'

mas "1Password for Safari", id: 1569813296
mas "Bear",                 id: 1091189122
mas "Calendars",            id: 608834326
mas "GarageBand",           id: 682658836
mas "iMovie",               id: 408981434
mas "Keynote",              id: 409183694
mas "Kindle",               id: 302584613
mas "Logic Pro",            id: 634148309
mas "Microsoft To Do",      id: 1274495053
mas "MindNode Classic",     id: 1289197285
mas "Night Sky",            id: 475772902
mas "Numbers",              id: 409203825
mas "Pages",                id: 409201541
mas "Scrivener",            id: 1310686187
mas "Slack",                id: 803453959
mas "Spark Desktop",        id: 6445813049
mas "Streaks",              id: 963034692
mas "Studio",               id: 6742413894
mas "Xcode",                id: 497799835

MAS_BREWFILE

echo "✔ brew bundle complete."
{{ end -}}
